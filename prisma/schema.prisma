generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  reader
}

enum BookFormat {
  epub
  physical
  pdf
  cbz
  cbr
  audiobook
}

enum MetadataSource {
  manual
  epub
  openlibrary
  calibre
}

enum ExternalCatalogProvider {
  openlibrary
  googlebooks
}

enum ShelfType {
  manual
  dynamic
  favorites
  reading
}

enum ProgressStatus {
  not_started
  reading
  finished
  abandoned
}

enum AnnotationType {
  highlight
  note
  bookmark
}

enum ThemePreference {
  light
  dark
  system
}

enum ReaderTheme {
  light
  dark
  sepia
}

enum ReaderFlow {
  paginated
  scrolled
}

enum LibraryView {
  grid
  list
}

enum DuplicateKind {
  hash
  fuzzy
}

enum DuplicateStatus {
  open
  ignored
  merged
}

enum DuplicateAuditAction {
  ignored
  merged
}

enum AdminAuditAction {
  epub_ingest
  calibre_import
  book_purge
  duplicate_ignore
  duplicate_merge
  mcp_tool_call
  pull_books
  pull_books_job_create
  pull_books_job_cancel
  pull_books_job_retry
  metadata_merge_preview
  metadata_merge_commit
}

enum AdminImportJobType {
  pull_books
}

enum AdminImportJobStatus {
  queued
  running
  succeeded
  failed
  cancelled
  dead_letter
}

enum RecommendationFeedbackKind {
  like
  dislike
}

enum RecommendationAnalyticsEventType {
  impression
  click
  dismiss
  like
  dislike
}

enum RecommendationAnalyticsSource {
  carousel
  page
  mcp
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  username     String    @unique @db.VarChar(100)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  role         UserRole  @default(reader)
  avatarUrl    String?   @map("avatar_url")
  oidcProvider String?   @map("oidc_provider") @db.VarChar(100)
  oidcSub      String?   @map("oidc_sub") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  booksAdded      Book[]                     @relation("BooksAdded")
  shelves         Shelf[]
  progress        UserBookProgress[]
  annotations     UserAnnotation[]
  preference      UserPreference?
  recommendations UserRecommendation[]
  apiKeys         ApiKey[]
  duplicateAudits DuplicateResolutionAudit[]
  adminAuditLogs  AdminAuditLog[]
  importJobs      AdminImportJob[]
  metadataMergeResolutionAudits MetadataMergeResolutionAudit[]
  recommendationFeedback          UserRecommendationFeedback[]
  recommendationAnalyticsEvents   RecommendationAnalyticsEvent[]

  @@map("users")
}

model Book {
  id             String                   @id @default(uuid()) @db.Uuid
  title          String                   @db.VarChar(500)
  subtitle       String?                  @db.VarChar(500)
  authors        Json                     @default("[]")
  isbn10         String?                  @map("isbn_10") @db.VarChar(10)
  isbn13         String?                  @map("isbn_13") @db.VarChar(13)
  publisher      String?                  @db.VarChar(255)
  publishDate    String?                  @map("publish_date") @db.VarChar(50)
  language       String?                  @db.VarChar(10)
  description    String?
  pageCount      Int?                     @map("page_count")
  subjects       Json                     @default("[]")
  coverUrl       String?                  @map("cover_url")
  format         BookFormat
  contentHash    String?                  @map("content_hash") @db.VarChar(64)
  openLibraryId  String?                  @map("open_library_id") @db.VarChar(50)
  externalCatalogProvider ExternalCatalogProvider? @map("external_catalog_provider")
  externalCatalogId String?               @map("external_catalog_id") @db.VarChar(255)
  externalCatalogQuery String?            @map("external_catalog_query") @db.VarChar(200)
  metadataSource MetadataSource           @map("metadata_source")
  addedById      String                   @map("added_by") @db.Uuid
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?                @map("deleted_at") @db.Timestamptz(6)
  searchVector   Unsupported("tsvector")? @map("search_vector")

  addedBy                  User                       @relation("BooksAdded", fields: [addedById], references: [id])
  files                    BookFile[]
  snapshot                 BookMetadataSnapshot?
  shelves                  BookShelf[]
  tags                     BookTag[]
  progress                 UserBookProgress[]
  annotations              UserAnnotation[]
  recommendations          UserRecommendation[]
  duplicatePairsAsA        DuplicatePair[]            @relation("DuplicatePairBookA")
  duplicatePairsAsB        DuplicatePair[]            @relation("DuplicatePairBookB")
  duplicatePairsMergedInto DuplicatePair[]            @relation("DuplicatePairMergedIntoBook")
  duplicateAuditsPrimary   DuplicateResolutionAudit[] @relation("DuplicateAuditPrimaryBook")
  duplicateAuditsAbsorbed  DuplicateResolutionAudit[] @relation("DuplicateAuditAbsorbedBook")
  metadataMergeResolutionAudits MetadataMergeResolutionAudit[]
  recommendationFeedback          UserRecommendationFeedback[]
  recommendationAnalyticsEvents   RecommendationAnalyticsEvent[]

  @@index([contentHash])
  @@index([isbn13])
  @@index([openLibraryId])
  @@index([externalCatalogProvider, externalCatalogId])
  @@index([deletedAt])
  @@index([language])
  @@index([format])
  @@index([pageCount])
  @@index([createdAt])
  @@map("books")
}

model BookFile {
  id          String   @id @default(uuid()) @db.Uuid
  bookId      String   @map("book_id") @db.Uuid
  filename    String   @db.VarChar(500)
  storagePath String   @map("storage_path")
  fileSize    BigInt   @map("file_size")
  mimeType    String   @map("mime_type") @db.VarChar(100)
  contentHash String   @map("content_hash") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  book Book @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@index([contentHash])
  @@map("book_files")
}

model BookMetadataSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @unique @map("book_id") @db.Uuid
  epubMetadata Json     @map("epub_metadata")
  dbMetadata   Json     @map("db_metadata")
  syncedAt     DateTime @map("synced_at") @db.Timestamptz(6)

  book Book @relation(fields: [bookId], references: [id])

  @@map("book_metadata_snapshots")
}

model Shelf {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  description String?
  type        ShelfType
  ownerId     String    @map("owner_id") @db.Uuid
  isPublic    Boolean   @default(false) @map("is_public")
  icon        String?   @db.VarChar(50)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner User        @relation(fields: [ownerId], references: [id])
  rule  ShelfRule?
  books BookShelf[]

  @@index([ownerId])
  @@index([ownerId, type])
  @@index([ownerId, sortOrder])
  @@map("shelves")
}

model ShelfRule {
  id      String @id @default(uuid()) @db.Uuid
  shelfId String @unique @map("shelf_id") @db.Uuid
  rules   Json

  shelf Shelf @relation(fields: [shelfId], references: [id])

  @@map("shelf_rules")
}

model BookShelf {
  bookId    String   @map("book_id") @db.Uuid
  shelfId   String   @map("shelf_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz(6)
  sortOrder Int      @default(0) @map("sort_order")

  book  Book  @relation(fields: [bookId], references: [id])
  shelf Shelf @relation(fields: [shelfId], references: [id])

  @@id([bookId, shelfId])
  @@index([shelfId])
  @@index([shelfId, sortOrder])
  @@index([shelfId, addedAt])
  @@map("book_shelves")
}

model Tag {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique @db.VarChar(100)
  color String @db.VarChar(7)

  books BookTag[]

  @@map("tags")
}

model BookTag {
  bookId String @map("book_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  book Book @relation(fields: [bookId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([bookId, tagId])
  @@index([tagId])
  @@map("book_tags")
}

model UserBookProgress {
  id                   String         @id @default(uuid()) @db.Uuid
  userId               String         @map("user_id") @db.Uuid
  bookId               String         @map("book_id") @db.Uuid
  progress             Float          @default(0)
  currentCfi           String?        @map("current_cfi")
  currentPage          Int?           @map("current_page")
  status               ProgressStatus @default(not_started)
  startedAt            DateTime?      @map("started_at") @db.Timestamptz(6)
  finishedAt           DateTime?      @map("finished_at") @db.Timestamptz(6)
  totalReadingSeconds  Int            @default(0) @map("total_reading_seconds")
  lastProgressClientAt DateTime?      @map("last_progress_client_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId])
  @@map("user_book_progress")
}

model UserAnnotation {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  bookId    String         @map("book_id") @db.Uuid
  type      AnnotationType
  cfiRange  String         @map("cfi_range")
  content   String?
  note      String?
  color     String?        @db.VarChar(7)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@index([userId, bookId])
  @@map("user_annotations")
}

model UserPreference {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @unique @map("user_id") @db.Uuid
  theme            ThemePreference @default(system)
  readerFontFamily String?         @map("reader_font_family") @db.VarChar(100)
  readerFontSize   Int?            @map("reader_font_size")
  readerLineHeight Float?          @map("reader_line_height")
  readerMargin     Int?            @map("reader_margin")
  readerTheme      ReaderTheme?    @map("reader_theme")
  readerFlow       ReaderFlow?     @map("reader_flow")
  libraryView      LibraryView?    @map("library_view")
  booksPerPage     Int             @default(24) @map("books_per_page")
  libraryInfiniteScroll Boolean    @default(false) @map("library_infinite_scroll")
  recommendationsCollaborativeEnabled Boolean @default(true) @map("recommendations_collaborative_enabled")

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model UserRecommendation {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  bookId     String   @map("book_id") @db.Uuid
  score      Float
  reasons    Json
  seen       Boolean  @default(false)
  dismissed  Boolean  @default(false)
  computedAt DateTime @map("computed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId])
  @@index([userId, dismissed, score])
  @@map("user_recommendations")
}

model UserRecommendationFeedback {
  id        String                   @id @default(uuid()) @db.Uuid
  userId    String                   @map("user_id") @db.Uuid
  bookId    String                   @map("book_id") @db.Uuid
  kind      RecommendationFeedbackKind
  createdAt DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("user_recommendation_feedback")
}

model RecommendationAnalyticsEvent {
  id        String                         @id @default(uuid()) @db.Uuid
  userId    String                         @map("user_id") @db.Uuid
  bookId    String                         @map("book_id") @db.Uuid
  event     RecommendationAnalyticsEventType
  source    RecommendationAnalyticsSource
  createdAt DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@map("recommendation_analytics_events")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String    @db.VarChar(100)
  prefix     String    @db.VarChar(16)
  hash       String    @db.VarChar(255)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([hash])
  @@map("api_keys")
}

model DuplicatePair {
  id               String          @id @default(uuid()) @db.Uuid
  kind             DuplicateKind
  status           DuplicateStatus @default(open)
  bookIdA          String          @map("book_id_a") @db.Uuid
  bookIdB          String          @map("book_id_b") @db.Uuid
  score            Float?
  lastScannedAt    DateTime        @map("last_scanned_at") @db.Timestamptz(6)
  mergedIntoBookId String?         @map("merged_into_book_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  bookA          Book                       @relation("DuplicatePairBookA", fields: [bookIdA], references: [id])
  bookB          Book                       @relation("DuplicatePairBookB", fields: [bookIdB], references: [id])
  mergedIntoBook Book?                      @relation("DuplicatePairMergedIntoBook", fields: [mergedIntoBookId], references: [id])
  audits         DuplicateResolutionAudit[]

  @@unique([kind, bookIdA, bookIdB])
  @@index([status])
  @@index([kind])
  @@index([lastScannedAt])
  @@map("duplicate_pairs")
}

model DuplicateResolutionAudit {
  id             String               @id @default(uuid()) @db.Uuid
  pairId         String               @map("pair_id") @db.Uuid
  actorId        String               @map("actor_id") @db.Uuid
  action         DuplicateAuditAction
  primaryBookId  String?              @map("primary_book_id") @db.Uuid
  absorbedBookId String?              @map("absorbed_book_id") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  meta           Json                 @default("{}") @map("meta")

  pair         DuplicatePair @relation(fields: [pairId], references: [id])
  actor        User          @relation(fields: [actorId], references: [id])
  primaryBook  Book?         @relation("DuplicateAuditPrimaryBook", fields: [primaryBookId], references: [id])
  absorbedBook Book?         @relation("DuplicateAuditAbsorbedBook", fields: [absorbedBookId], references: [id])

  @@index([pairId])
  @@index([actorId])
  @@index([createdAt])
  @@map("duplicate_resolution_audits")
}

model AdminAuditLog {
  id        String           @id @default(uuid()) @db.Uuid
  action    AdminAuditAction
  actorId   String           @map("actor_id") @db.Uuid
  meta      Json             @default("{}")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User @relation(fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}

// Detailed audit trail for admin metadata merge decisions (three-way + manual arbitration).
model MetadataMergeResolutionAudit {
  id                  String   @id @default(uuid()) @db.Uuid
  bookId              String   @map("book_id") @db.Uuid
  actorId             String   @map("actor_id") @db.Uuid
  snapshotSyncedAtIso String?  @map("snapshot_synced_at_iso") @db.VarChar(40)
  input               Json     @default("{}")
  fieldDecisions      Json     @default("[]") @map("field_decisions")
  result              Json     @default("{}")
  writeback           Boolean  @default(false)
  oldContentHash      String?  @map("old_content_hash") @db.VarChar(64)
  newContentHash      String?  @map("new_content_hash") @db.VarChar(64)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  book  Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id])

  @@index([bookId, createdAt])
  @@index([actorId, createdAt])
  @@map("metadata_merge_resolution_audits")
}

model AdminImportJob {
  id                String               @id @default(uuid()) @db.Uuid
  type              AdminImportJobType
  status            AdminImportJobStatus @default(queued)
  params            Json
  processedCandidates Int                @default(0) @map("processed_candidates")
  createdCount      Int                  @default(0) @map("created_count")
  updatedCount      Int                  @default(0) @map("updated_count")
  skippedCount      Int                  @default(0) @map("skipped_count")
  errorCount        Int                  @default(0) @map("error_count")
  attempts          Int                  @default(0)
  maxAttempts       Int                  @default(3) @map("max_attempts")
  lastCursor        String?              @map("last_cursor")
  nextRunAt         DateTime?            @map("next_run_at") @db.Timestamptz(6)
  lockedAt          DateTime?            @map("locked_at") @db.Timestamptz(6)
  lockOwner         String?              @map("lock_owner") @db.VarChar(100)
  cancelRequestedAt DateTime?            @map("cancel_requested_at") @db.Timestamptz(6)
  startedAt         DateTime?            @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?            @map("finished_at") @db.Timestamptz(6)
  lastError         String?              @map("last_error")
  createdById       String               @map("created_by_id") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User                 @relation(fields: [createdById], references: [id])
  items     AdminImportJobItem[]

  @@index([type, status, nextRunAt])
  @@index([createdAt])
  @@index([createdById, createdAt])
  @@index([status, updatedAt])
  @@map("admin_import_jobs")
}

model AdminImportJobItem {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  status    String   @db.VarChar(20)
  title     String   @db.VarChar(500)
  authors   Json     @default("[]")
  openLibraryId String? @map("open_library_id") @db.VarChar(50)
  isbn13    String?  @map("isbn_13") @db.VarChar(13)
  error     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  job AdminImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("admin_import_job_items")
}
