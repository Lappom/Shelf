generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  reader
}

enum BookFormat {
  epub
  physical
  pdf
  cbz
  cbr
  audiobook
}

enum MetadataSource {
  manual
  epub
  openlibrary
  calibre
}

enum ShelfType {
  manual
  dynamic
  favorites
  reading
}

enum ProgressStatus {
  not_started
  reading
  finished
  abandoned
}

enum AnnotationType {
  highlight
  note
  bookmark
}

enum ThemePreference {
  light
  dark
  system
}

enum ReaderTheme {
  light
  dark
  sepia
}

enum LibraryView {
  grid
  list
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  username      String   @unique @db.VarChar(100)
  passwordHash  String?  @map("password_hash") @db.VarChar(255)
  role          UserRole @default(reader)
  avatarUrl     String?  @map("avatar_url")
  oidcProvider  String?  @map("oidc_provider") @db.VarChar(100)
  oidcSub       String?  @map("oidc_sub") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  booksAdded    Book[] @relation("BooksAdded")
  shelves       Shelf[]
  progress      UserBookProgress[]
  annotations   UserAnnotation[]
  preference    UserPreference?
  recommendations UserRecommendation[]
  apiKeys       ApiKey[]

  @@map("users")
}

model Book {
  id             String        @id @default(uuid()) @db.Uuid
  title          String        @db.VarChar(500)
  subtitle       String?       @db.VarChar(500)
  authors        Json          @default("[]")
  isbn10         String?       @map("isbn_10") @db.VarChar(10)
  isbn13         String?       @map("isbn_13") @db.VarChar(13)
  publisher      String?       @db.VarChar(255)
  publishDate    String?       @map("publish_date") @db.VarChar(50)
  language       String?       @db.VarChar(10)
  description    String?
  pageCount      Int?          @map("page_count")
  subjects       Json          @default("[]")
  coverUrl       String?       @map("cover_url")
  format         BookFormat
  contentHash    String?       @map("content_hash") @db.VarChar(64)
  openLibraryId  String?       @map("open_library_id") @db.VarChar(50)
  metadataSource MetadataSource @map("metadata_source")
  addedById      String        @map("added_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  searchVector   Unsupported("tsvector")? @map("search_vector")

  addedBy        User          @relation("BooksAdded", fields: [addedById], references: [id])
  files          BookFile[]
  snapshot       BookMetadataSnapshot?
  shelves        BookShelf[]
  tags           BookTag[]
  progress       UserBookProgress[]
  annotations    UserAnnotation[]
  recommendations UserRecommendation[]

  @@index([contentHash])
  @@index([isbn13])
  @@index([deletedAt])
  @@map("books")
}

model BookFile {
  id          String   @id @default(uuid()) @db.Uuid
  bookId      String   @map("book_id") @db.Uuid
  filename    String   @db.VarChar(500)
  storagePath String   @map("storage_path")
  fileSize    BigInt   @map("file_size")
  mimeType    String   @map("mime_type") @db.VarChar(100)
  contentHash String   @map("content_hash") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  book        Book     @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@index([contentHash])
  @@map("book_files")
}

model BookMetadataSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @unique @map("book_id") @db.Uuid
  epubMetadata Json     @map("epub_metadata")
  dbMetadata   Json     @map("db_metadata")
  syncedAt     DateTime @map("synced_at") @db.Timestamptz(6)

  book         Book     @relation(fields: [bookId], references: [id])

  @@map("book_metadata_snapshots")
}

model Shelf {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  description String?
  type        ShelfType
  ownerId     String    @map("owner_id") @db.Uuid
  isPublic    Boolean   @default(false) @map("is_public")
  icon        String?   @db.VarChar(50)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner       User      @relation(fields: [ownerId], references: [id])
  rule        ShelfRule?
  books       BookShelf[]

  @@unique([ownerId, type])
  @@index([ownerId])
  @@map("shelves")
}

model ShelfRule {
  id      String @id @default(uuid()) @db.Uuid
  shelfId String @unique @map("shelf_id") @db.Uuid
  rules   Json

  shelf   Shelf  @relation(fields: [shelfId], references: [id])

  @@map("shelf_rules")
}

model BookShelf {
  bookId    String   @map("book_id") @db.Uuid
  shelfId   String   @map("shelf_id") @db.Uuid
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz(6)
  sortOrder Int      @default(0) @map("sort_order")

  book      Book     @relation(fields: [bookId], references: [id])
  shelf     Shelf    @relation(fields: [shelfId], references: [id])

  @@id([bookId, shelfId])
  @@index([shelfId])
  @@map("book_shelves")
}

model Tag {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique @db.VarChar(100)
  color String @db.VarChar(7)

  books BookTag[]

  @@map("tags")
}

model BookTag {
  bookId String @map("book_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  book   Book   @relation(fields: [bookId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([bookId, tagId])
  @@index([tagId])
  @@map("book_tags")
}

model UserBookProgress {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  bookId      String         @map("book_id") @db.Uuid
  progress    Float          @default(0)
  currentCfi  String?        @map("current_cfi")
  currentPage Int?           @map("current_page")
  status      ProgressStatus @default(not_started)
  startedAt   DateTime?      @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime?      @map("finished_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User           @relation(fields: [userId], references: [id])
  book        Book           @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId])
  @@map("user_book_progress")
}

model UserAnnotation {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  bookId    String         @map("book_id") @db.Uuid
  type      AnnotationType
  cfiRange  String         @map("cfi_range")
  content   String?
  note      String?
  color     String?        @db.VarChar(7)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User           @relation(fields: [userId], references: [id])
  book      Book           @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@map("user_annotations")
}

model UserPreference {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @unique @map("user_id") @db.Uuid
  theme           ThemePreference @default(system)
  readerFontFamily String?        @map("reader_font_family") @db.VarChar(100)
  readerFontSize  Int?            @map("reader_font_size")
  readerLineHeight Float?         @map("reader_line_height")
  readerMargin    Int?            @map("reader_margin")
  readerTheme     ReaderTheme?    @map("reader_theme")
  libraryView     LibraryView?    @map("library_view")
  booksPerPage    Int             @default(24) @map("books_per_page")

  user            User            @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model UserRecommendation {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  bookId     String   @map("book_id") @db.Uuid
  score      Float
  reasons    Json
  seen       Boolean  @default(false)
  dismissed  Boolean  @default(false)
  computedAt DateTime @map("computed_at") @db.Timestamptz(6)

  user       User     @relation(fields: [userId], references: [id])
  book       Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([bookId])
  @@map("user_recommendations")
}

model ApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  prefix    String   @db.VarChar(16)
  hash      String   @db.VarChar(255)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("api_keys")
}

